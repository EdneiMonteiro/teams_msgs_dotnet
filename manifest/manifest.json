{
  "$schema": "https://developer.microsoft.com/json-schemas/teams/v1.17/MicrosoftTeams.schema.json",
  "manifestVersion": "1.17",
  "version": "1.0.0",
  "id": "<MICROSOFT_APP_ID>",
  "developer": {
    "name": "Your Company",
    "websiteUrl": "https://<your-api-fqdn>",
    "privacyUrl": "https://<your-api-fqdn>/privacy",
    "termsOfUseUrl": "https://<your-api-fqdn>/terms"
  },
  "name": {
    "short": "Notifications",
    "full": "Proactive Notifications System"
  },
  "description": {
    "short": "Receive notifications and announcements from your organization",
    "full": "Bot for sending bulk notifications and announcements to organization members via 1:1 chat in Microsoft Teams."
  },
  "icons": {
    "color": "color.png",
    "outline": "outline.png"
  },
  "accentColor": "#0078D4",
  "bots": [
    {
      "botId": "<MICROSOFT_APP_ID>",
      "scopes": ["personal"],
      "supportsFiles": false,
      "isNotificationOnly": true,
      "commandLists": []
    }
  ],
  "permissions": ["identity", "messageTeamMembers"],
  "validDomains": [
    "<your-api-fqdn>"
  ],
  "defaultInstallScope": "personal",
  "defaultGroupCapability": {}
}

